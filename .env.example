# Production app
NODE_ENV=production
PORT=10000
APP_URL=https://api.vibepass.lk
FRONTEND_URL=https://vibepass.lk,https://www.vibepass.lk
FRONTEND_PATH=
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
DB_CONNECTION_LIMIT=10
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=7d

# Super admin bootstrap
# Used by: npm run seed:admin
SUPER_ADMIN_NAME=VibePass Super Admin
SUPER_ADMIN_EMAIL=admin@vibepass.lk
SUPER_ADMIN_PASSWORD=replace-this-before-launch

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.vibepass.lk/api/auth/google/callback

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
PAYPAL_WEBHOOK_ID=

# Future notification providers
EMAIL_FROM=no-reply@vibepass.lk
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_PROVIDER=
SMS_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Uploads
UPLOAD_MAX_MB=8
