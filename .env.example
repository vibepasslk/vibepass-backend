# =========================
# App Configuration
# =========================
NODE_ENV=production
PORT=10000
APP_URL=https://api.vibepass.lk
FRONTEND_URL=https://vibepass.lk,https://www.vibepass.lk
FRONTEND_PATH=

# =========================
# Database (Render PostgreSQL / Supabase compatible)
# =========================
DATABASE_URL=postgresql://username:password@host:port/database
DB_CONNECTION_LIMIT=10
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# =========================
# Authentication (JWT)
# =========================
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# =========================
# Admin Bootstrap (DO NOT expose in public repos in real projects)
# =========================
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change_this_password

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.vibepass.lk/api/auth/google/callback

# =========================
# Payment (PayPal)
# =========================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=live
PAYPAL_WEBHOOK_ID=

# =========================
# Email / SMS / WhatsApp
# =========================
EMAIL_FROM=no-reply@vibepass.lk
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

SMS_PROVIDER=
SMS_API_KEY=

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# =========================
# File Uploads
# =========================
UPLOAD_MAX_MB=8

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
